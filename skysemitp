local function makeStroke(parent, color, thickness, transparency)
	local s = Instance.new("UIStroke", parent)
	s.Color        = color or C_WHITE
	s.Thickness    = thickness or 1
	s.Transparency = transparency or 0
	return s
end

local function createToggle(text, yPos, callback)
	local state = false
	local btn = Instance.new("TextButton")
	btn.Size             = UDim2.new(1, -20, 0, 36)
	btn.Position         = UDim2.new(0, 10, 0, yPos)
	btn.BackgroundColor3 = C_BTN
	btn.BackgroundTransparency = 0.4
	btn.Text             = text .. ": OFF"
	btn.TextColor3       = C_GRAY
	btn.TextSize         = 11
	btn.Font             = Enum.Font.GothamBlack
	btn.BorderSizePixel  = 0
	btn.ZIndex           = 2
	btn.Parent           = mainFrame
	Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 8)

	btn.MouseEnter:Connect(function()
		TweenService:Create(btn, TweenInfo.new(0.1), {BackgroundTransparency = 0.1}):Play()
	end)
	btn.MouseLeave:Connect(function()
		TweenService:Create(btn, TweenInfo.new(0.1), {BackgroundTransparency = state and 0.2 or 0.4}):Play()
	end)
	btn.MouseButton1Click:Connect(function()
		state = not state
		btn.Text       = text .. (state and ": ON" or ": OFF")
		btn.TextColor3 = state and C_WHITE or C_GRAY
		TweenService:Create(btn, TweenInfo.new(0.15), {
			BackgroundColor3       = state and Color3.fromRGB(40, 40, 40) or C_BTN,
			BackgroundTransparency = state and 0.2 or 0.4,
		}):Play()
		callback(state)
	end)
	return btn
end

