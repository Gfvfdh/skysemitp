		local white = Color3.fromRGB(255, 255, 255)
		local gray  = Color3.fromRGB(160, 160, 160)
		local mixed = Color3.new(
			white.R + (gray.R - white.R) * pulse,
			white.G + (gray.G - white.G) * pulse,
			white.B + (gray.B - white.B) * pulse
		)
		for _, beam in ipairs(beamData) do
			beam.Color = ColorSequence.new(mixed)
		end
		task.wait(0.03)
	end
end)

